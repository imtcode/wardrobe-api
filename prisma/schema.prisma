// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  STAFF
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String
  mobile   String
  password String
  role     Role   @default(STAFF)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  otpCodes OtpCode[]
}

model Session {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  token     String
  ipAddress String?
  userAgent String?
  expiresAt DateTime

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model OtpCode {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  code      String
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Location {
  id       Int       @id @default(autoincrement())
  name     String
  parentId Int?
  parent   Location? @relation("LocationTree", fields: [parentId], references: [id])

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  children Location[] @relation("LocationTree")
  items    Item[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  parentId Int?
  parent   Category? @relation("CategoryTree", fields: [parentId], references: [id])

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  children Category[]      @relation("CategoryTree")
  items    Item[]
  fields   CategoryField[]
}

enum Condition {
  NEW
  GOOD
  FAIR
  POOR
}

enum FieldType {
  TEXT
  NUMBER
  DATE
  SELECT
}

model Item {
  id         Int        @id @default(autoincrement())
  name       String
  brand      String?
  color      String?
  condition  Condition?
  categoryId Int?
  locationId Int?
  images     Json?

  category Category? @relation(fields: [categoryId], references: [id])
  location Location? @relation(fields: [locationId], references: [id])

  fieldValues ItemFieldValue[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategoryField {
  id         Int       @id @default(autoincrement())
  categoryId Int
  name       String
  fieldType  FieldType
  options    Json? // string[]
  isRequired Boolean   @default(false)

  category Category         @relation(fields: [categoryId], references: [id])
  values   ItemFieldValue[]

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ItemFieldValue {
  id      Int    @id @default(autoincrement())
  itemId  Int
  fieldId Int
  value   String

  item  Item          @relation(fields: [itemId], references: [id])
  field CategoryField @relation(fields: [fieldId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
